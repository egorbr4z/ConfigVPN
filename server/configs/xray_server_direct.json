{
  "_comment": [
    "PHANTOM — Direct mode Xray server config.",
    "Xray listens on a LOCAL plaintext WebSocket port (127.0.0.1:10000).",
    "nginx terminates TLS on :443 and reverse-proxies the secret path here,",
    "serving real web content for every other request (anti-probe).",
    "Replace: PHANTOM_TOKEN, USER_UUID_1 ... USER_UUID_N",
    "",
    "Generate PHANTOM_TOKEN: python3 -c \"",
    "  import hmac, hashlib",
    "  s='YOUR_SECRET'; k=hashlib.sha256(s.encode()).digest()",
    "  print(hmac.new(k, b'phantom-v1', hashlib.sha256).digest()[:16].hex())",
    "\""
  ],
  "log": {
    "loglevel": "warning",
    "access": "/var/log/xray/access.log",
    "error": "/var/log/xray/error.log"
  },
  "inbounds": [
    {
      "tag": "phantom-inbound",
      "listen": "127.0.0.1",
      "port": 10000,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "USER_UUID_1",
            "flow": "",
            "level": 0
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "ws",
        "security": "none",
        "wsSettings": {
          "_comment": "TLS is terminated by nginx; nginx only forwards this exact path here",
          "path": "/phantom/PHANTOM_TOKEN"
        }
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct",
      "settings": {}
    },
    {
      "protocol": "blackhole",
      "tag": "block"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "_comment": "Block access to RFC-1918/loopback from VPN clients",
        "type": "field",
        "ip": ["geoip:private"],
        "outboundTag": "block"
      },
      {
        "_comment": "Catch-all → direct (needs a matcher field; recent Xray rejects empty rules)",
        "type": "field",
        "network": "tcp,udp",
        "outboundTag": "direct"
      }
    ]
  }
}
