{
  "_comment": [
    "PHANTOM — CDN mode Xray server config.",
    "Xray listens on a unix socket; the PHANTOM Doorman handles HTTP.",
    "CDN → Doorman (HTTP:8001) → Xray (unix:/tmp/phantom.sock) → Internet",
    "",
    "Replace: PHANTOM_TOKEN, USER_UUID_1 ... USER_UUID_N"
  ],
  "log": {
    "loglevel": "warning",
    "access": "/var/log/xray/access.log",
    "error": "/var/log/xray/error.log"
  },
  "inbounds": [
    {
      "tag": "phantom-cdn-inbound",
      "listen": "/tmp/phantom.sock,0666",
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "USER_UUID_1",
            "flow": "",
            "level": 0
          }
        ],
        "decryption": "none",
        "fallbacks": []
      },
      "streamSettings": {
        "network": "ws",
        "security": "none",
        "wsSettings": {
          "path": "/phantom/PHANTOM_TOKEN"
        }
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct",
      "settings": {}
    },
    {
      "protocol": "blackhole",
      "tag": "block"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "ip": ["geoip:private"],
        "outboundTag": "block"
      },
      {
        "type": "field",
        "outboundTag": "direct"
      }
    ]
  }
}
