# Main bot token (from @BotFather)
MAIN_BOT_TOKEN=your_main_bot_token_here

# Admin bot token (from @BotFather, separate bot)
ADMIN_BOT_TOKEN=your_admin_bot_token_here

# Telegram IDs of admins (comma-separated)
ADMIN_IDS=123456789,987654321

# Bot username for referral links (without @)
BOT_USERNAME=your_main_bot_username

# Path to data directory (default: ./data)
DATA_DIR=./data
